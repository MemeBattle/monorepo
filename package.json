{
  "name": "@memebattle/memebattle",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test:ci": "pnpm run --parallel --no-bail test:ci",
    "blog:test:ci": "pnpm run --filter @memebattle/blog test:ci",
    "ligretto:test:ci": "pnpm run --parallel --no-bail --filter '@memebattle/ligretto-*' test:ci",
    "ligretto:ts-check:ci": "pnpm run --parallel --no-bail --filter '@memebattle/ligretto-*' ts-check",
    "ligretto:start": "pnpm run --parallel --no-bail --filter '@memebattle/ligretto-*' start:dev",
    "ligretto:front:build": "pnpm run --filter @memebattle/ligretto-frontend build",
    "ligretto:front:start:dev": "pnpm run --filter @memebattle/ligretto-frontend start:dev",
    "ligretto:gameplay-backend:start:dev": "pnpm run --filter @memebattle/ligretto-gameplay-backend start:dev",
    "ligretto:gameplay-backend:build": "pnpm run --filter @memebattle/ligretto-gameplay-backend build",
    "ligretto:core-backend:build": "pnpm run --filter @memebattle/ligretto-core-backend build",
    "ligretto:core-backend:migrate": "pnpm run --filter @memebattle/ligretto-core-backend migrate",
    "ligretto:core-backend:start:dev": "pnpm run --filter @memebattle/ligretto-core-backend start:dev",
    "ligretto-shared:build": "pnpm run --filter @memebattle/ligretto-shared build",
    "ts-check": "pnpm run --parallel --no-bail ts-check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@mui/material": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sass": "^1.54.9",
    "storybook": "catalog:",
    "vite": "catalog:",
    "vite-plugin-svgr": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "wait-on": "catalog:"
  },
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "contentlayer",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:",
      "@types/node": "catalog:"
    }
  }
}
